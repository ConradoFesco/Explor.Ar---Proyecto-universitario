{# templates/features/reviews/_list_fragment.html.jinja #}
{% from 'components/paginator.html.jinja' import render_pagination %}

{% if items %}
<table class="w-full divide-y divide-gray-200 table-fixed">
  <colgroup>
    <col style="width: 20%;"> 
    <col style="width: 15%;"> 
    <col style="width: 5%;"> 
    <col style="width: 35%;"> 
    <col style="width: 10%;"> 
    <col style="width: 10%;">
    {% if show_rejection_reason_column %}
      <col style="width: 10%;">
    {% endif %}
    <col style="width: 15%;"> 
  </colgroup>
  <thead class="bg-gray-50">
    <tr>
      <th class="px-3 py-2 text-left text-sm font-medium text-gray-500">Sitio</th>
      <th class="px-3 py-2 text-left text-sm font-medium text-gray-500">Usuario (email)</th>
      <th class="px-2 py-2 text-center text-sm font-medium text-gray-500">
        <span class="text-yellow-400">★</span>
      </th>
      <th class="px-3 py-2 text-left text-sm font-medium text-gray-500">Contenido</th>
      <th class="px-2 py-2 text-left text-sm font-medium text-gray-500">Estado</th>
      <th class="px-2 py-2 text-left text-sm font-medium text-gray-500">Fecha</th>
      {% if show_rejection_reason_column %}
        <th class="px-3 py-2 text-left text-sm font-medium text-gray-500">Motivo de rechazo</th>
      {% endif %}
      <th class="px-2 py-2 text-right text-sm font-medium text-gray-500">Acciones</th>
    </tr>
  </thead>
  <tbody class="bg-white divide-y divide-gray-200">
    {% for review in items %}
      {% include 'features/reviews/_item.html.jinja' %}
    {% endfor %}
  </tbody>
</table>

{% if pagination.pages > 1 %}
<div class="mt-4 flex items-center justify-between">
  <div class="text-sm text-gray-600">
    Mostrando {{ ((pagination.page - 1) * pagination.per_page + 1) if pagination.total > 0 else 0 }} a {{ (pagination.page * pagination.per_page) if (pagination.page * pagination.per_page) < pagination.total else pagination.total }} de {{ pagination.total }} reseñas
  </div>
  <div>
    <nav class="inline-flex -space-x-px">
      {% if pagination.has_prev %}
        <button data-page="{{ pagination.prev_num }}" class="pagination-btn px-3 py-1 border rounded-l hover:bg-gray-50">Anterior</button>
      {% endif %}
      {% if pagination.has_next %}
        <button data-page="{{ pagination.next_num }}" class="pagination-btn px-3 py-1 border rounded-r hover:bg-gray-50">Siguiente</button>
      {% endif %}
    </nav>
  </div>
</div>
{% endif %}
{% else %}
<div class="text-center text-gray-500 py-8">No se encontraron reseñas.</div>
{% endif %}
