{% macro render_site_form_fields(include_tags=False, include_visibility=False) %}
    <!-- Primera fila: Nombre y Año de Inauguración -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div>
            <label for="nombre" class="block text-sm font-medium text-gray-700 mb-1">Nombre *</label>
            <input type="text" id="nombre" name="nombre" required 
                   class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent"
                   placeholder="Ingrese el nombre del sitio">
            <div class="error-message hidden" id="nombre-error">El nombre es requerido</div>
        </div>
        <div>
            <label for="año_inauguración" class="block text-sm font-medium text-gray-700 mb-1">Año de Inauguración</label>
            <input type="number" id="año_inauguración" name="año_inauguración" min="1000" max="9999"
                   class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent"
                   placeholder="Ej: 1920">
        </div>
    </div>

    <!-- Segunda fila: Descripción breve -->
    <div>
        <label for="descripcion_breve" class="block text-sm font-medium text-gray-700 mb-1">Descripción Breve *</label>
        <textarea id="descripcion_breve" name="descripcion_breve" required rows="3"
                  class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent"
                  placeholder="Descripción corta del sitio histórico"></textarea>
        <div class="error-message hidden" id="descripcion_breve-error">La descripción breve es requerida</div>
    </div>

    <!-- Tercera fila: Descripción completa -->
    <div>
        <label for="descripcion_completa" class="block text-sm font-medium text-gray-700 mb-1">Descripción Completa</label>
        <textarea id="descripcion_completa" name="descripcion_completa" rows="4"
                  class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent"
                  placeholder="Descripción detallada del sitio histórico"></textarea>
    </div>

    <!-- Cuarta fila: Coordenadas (generadas automáticamente) -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div>
            <label for="latitud" class="block text-sm font-medium text-gray-700 mb-1">Latitud</label>
            <input type="number" id="latitud" name="latitud" step="any" readonly
                   class="w-full px-3 py-2 border border-gray-300 rounded-md bg-gray-100 text-gray-600"
                   placeholder="Se genera al seleccionar en el mapa">
            <div class="error-message hidden" id="latitud-error">Debe seleccionar una ubicación en el mapa</div>
        </div>
        <div>
            <label for="longitud" class="block text-sm font-medium text-gray-700 mb-1">Longitud</label>
            <input type="number" id="longitud" name="longitud" step="any" readonly
                   class="w-full px-3 py-2 border border-gray-300 rounded-md bg-gray-100 text-gray-600"
                   placeholder="Se genera al seleccionar en el mapa">
            <div class="error-message hidden" id="longitud-error">Debe seleccionar una ubicación en el mapa</div>
        </div>
    </div>

    <!-- Quinta fila: Ubicación (generada automáticamente) -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div>
            <label for="ciudad" class="block text-sm font-medium text-gray-700 mb-1">Ciudad</label>
            <input type="text" id="ciudad" name="ciudad" readonly
                   class="w-full px-3 py-2 border border-gray-300 rounded-md bg-gray-100 text-gray-600"
                   placeholder="Se genera al seleccionar en el mapa">
            <div class="error-message hidden" id="ciudad-error">Debe seleccionar una ubicación en el mapa para obtener la ciudad</div>
        </div>
        <div>
            <label for="provincia" class="block text-sm font-medium text-gray-700 mb-1">Provincia</label>
            <input type="text" id="provincia" name="provincia" readonly
                   class="w-full px-3 py-2 border border-gray-300 rounded-md bg-gray-100 text-gray-600"
                   placeholder="Se genera al seleccionar en el mapa">
            <div class="error-message hidden" id="provincia-error">Debe seleccionar una ubicación en el mapa para obtener la provincia</div>
        </div>
    </div>

    <!-- Sexta fila: Estado y Categoría (seleccionables) -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div>
            <label for="estado" class="block text-sm font-medium text-gray-700 mb-1">Estado *</label>
            <select id="estado" name="estado" required
                    class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent">
                <option value="">Seleccione un estado...</option>
            </select>
            <div class="error-message hidden" id="estado-error">Debe seleccionar un estado</div>
        </div>
        <div>
            <label for="categoria" class="block text-sm font-medium text-gray-700 mb-1">Categoría *</label>
            <select id="categoria" name="categoria" required
                    class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent">
                <option value="">Seleccione una categoría...</option>
            </select>
            <div class="error-message hidden" id="categoria-error">Debe seleccionar una categoría</div>
        </div>
    </div>

    {% if include_tags %}
    <!-- Selector de Tags -->
    <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Tags (opcional)</label>
        <div id="tag-selector-container"></div>
        <small class="text-gray-500">Haga clic en "Agregar Tags" para seleccionar tags que describan este sitio histórico</small>
    </div>
    {% endif %}

    {% if include_visibility %}
    <!-- Visibilidad -->
    <div class="flex items-center">
        <input type="checkbox"
               id="visible"
               name="visible"
               class="h-4 w-4 text-blue-600 focus:ring-blue-500 border-gray-300 rounded">
        <label for="visible" class="ml-2 block text-sm text-gray-700">
            Sitio visible al público
        </label>
        <span class="ml-2 text-xs text-gray-500">(Si está marcado, el sitio será visible en el mapa público)</span>
    </div>
    {% endif %}
{% endmacro %}


