<li class="py-4 flex justify-between items-center">
  <div class="flex-1 flex items-start gap-4">
    {% if site.cover_image %}
    <img src="{{ site.cover_image.url_publica }}" alt="{{ site.cover_image.titulo_alt }}" 
         class="w-24 h-24 object-cover rounded-md flex-shrink-0">
    {% else %}
    <div class="w-24 h-24 bg-gray-200 rounded-md flex-shrink-0 flex items-center justify-center">
      <span class="text-gray-400 text-xs">Sin imagen</span>
    </div>
    {% endif %}
    <div class="flex-1">
      <span class="text-lg font-medium text-gray-700">{{ site.name }}</span>
      <p class="text-sm text-gray-500 mt-1">{{ site.brief_description }}</p>
      <div class="flex flex-wrap gap-2 mt-1">
        {% if site.city_name %}<span class="text-xs text-gray-500">📍 {{ site.city_name }}</span>{% endif %}
        {% if site.created_at %}<span class="text-xs text-gray-500">📅 {{ site.created_at[:10] }}</span>{% endif %}
        <span class="text-xs text-gray-500">{{ '👁️ Visible' if site.visible else '🚫 No visible' }}</span>
      </div>
      {% if site.tags and site.tags|length > 0 %}
      <div class="flex flex-wrap gap-1 mt-2">
        {% for tag in site.tags %}
        <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium bg-blue-100 text-blue-800">{{ tag.name }}</span>
        {% endfor %}
      </div>
      {% endif %}
    </div>
  </div>
  <button type="button" onclick="openSiteDetail({{ site.id }})"
     class="bg-blue-500 hover:bg-blue-700 text-white font-bold py-2 px-4 rounded transition duration-200">
    Ver Detalle
  </button>
</li>

