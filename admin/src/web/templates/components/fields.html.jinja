{% macro render_checkbox(id, label) %}
<div class="flex items-center">
    <input type="checkbox"
           id="{{ id }}"
           name="{{ id }}"
           class="h-4 w-4 text-blue-600 focus:ring-blue-500 border-gray-300 rounded">
    <label for="{{ id }}" class="ml-2 block text-sm text-gray-700">{{ label }}</label>
    </div>
{% endmacro %}

{% macro render_password_input(id, label, required=True, placeholder='', minlength=6) %}
<div>
    <label for="{{ id }}" class="block text-sm font-medium text-gray-700 mb-1">
        {{ label }}{% if required %} <span class="text-red-500">*</span>{% endif %}
    </label>
    <input type="password"
           id="{{ id }}"
           name="{{ id }}"
           {% if required %}required{% endif %}
           {% if minlength %}minlength="{{ minlength }}"{% endif %}
           {% if placeholder %}placeholder="{{ placeholder }}"{% endif %}
           class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent">
</div>
{% endmacro %}

{% macro render_info_row(label, value_id) %}
<p class="text-sm text-gray-600">
    <span class="font-medium">{{ label }}:</span>
    <span id="{{ value_id }}">-</span>
</p>
{% endmacro %}


