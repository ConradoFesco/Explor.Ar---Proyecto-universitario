{# Componente de paginación reutilizable (idéntico al actual) #}
{% macro render_pagination(pagination) %}
    {% if pagination.pages <= 1 %}
        <div class="pagination hidden"></div>
    {% else %}
        <div class="pagination flex justify-center gap-2">
            {% if pagination.has_prev %}
                <button onclick="changePage({{ pagination.prev_num }})" 
                        class="px-3 py-2 text-sm border border-gray-300 rounded-lg hover:bg-gray-50 transition duration-200">
                    ← Anterior
                </button>
            {% else %}
                <button disabled 
                        class="px-3 py-2 text-sm border border-gray-300 rounded-lg opacity-50 cursor-not-allowed">
                    ← Anterior
                </button>
            {% endif %}
            {% set start_page = [1, pagination.page - 2] | max %}
            {% set end_page = [pagination.pages, pagination.page + 2] | min %}
            {% if start_page > 1 %}
                <button onclick="changePage(1)" 
                        class="px-3 py-2 text-sm border border-gray-300 rounded-lg hover:bg-gray-50 transition duration-200">
                    1
                </button>
                {% if start_page > 2 %}
                    <span class="px-2 text-gray-500">...</span>
                {% endif %}
            {% endif %}
            {% for page_num in range(start_page, end_page + 1) %}
                {% if page_num == pagination.page %}
                    <button class="px-3 py-2 text-sm border border-gray-300 rounded-lg bg-blue-600 text-white border-blue-600 transition duration-200">
                        {{ page_num }}
                    </button>
                {% else %}
                    <button onclick="changePage({{ page_num }})" 
                            class="px-3 py-2 text-sm border border-gray-300 rounded-lg hover:bg-gray-50 transition duration-200">
                        {{ page_num }}
                    </button>
                {% endif %}
            {% endfor %}
            {% if end_page < pagination.pages %}
                {% if end_page < pagination.pages - 1 %}
                    <span class="px-2 text-gray-500">...</span>
                {% endif %}
                <button onclick="changePage({{ pagination.pages }})" 
                        class="px-3 py-2 text-sm border border-gray-300 rounded-lg hover:bg-gray-50 transition duration-200">
                    {{ pagination.pages }}
                </button>
            {% endif %}
            {% if pagination.has_next %}
                <button onclick="changePage({{ pagination.next_num }})" 
                        class="px-3 py-2 text-sm border border-gray-300 rounded-lg hover:bg-gray-50 transition duration-200">
                    Siguiente →
                </button>
            {% else %}
                <button disabled 
                        class="px-3 py-2 text-sm border border-gray-300 rounded-lg opacity-50 cursor-not-allowed">
                    Siguiente →
                </button>
            {% endif %}
        </div>
        {% set start_item = 0 %}
        {% if pagination.total and pagination.total > 0 %}
            {% set start_item = (pagination.page - 1) * pagination.per_page + 1 %}
        {% endif %}
        {% set end_calc = pagination.page * pagination.per_page %}
        {% set end_item = end_calc if end_calc < pagination.total else pagination.total %}
        <div class="pagination-info mt-2 text-sm text-gray-600 text-center">
            Mostrando {{ start_item }} a {{ end_item }} de {{ pagination.total }} elementos
        </div>
    {% endif %}
{% endmacro %}

{# Paginación simple para JavaScript #}
{% macro render_pagination_js() %}
    <div id="pagination-controls" class="pagination hidden mt-6 flex justify-center gap-2"></div>
    <div id="pagination-info" class="pagination-info hidden mt-2 text-sm text-gray-600 text-center"></div>
{% endmacro %}

