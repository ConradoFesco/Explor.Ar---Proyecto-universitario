</a>

<!-- Gestión de Tags (NO accesible para usuario común) -->
{% if 'usuario' not in user_roles or is_admin or 'editor' in user_roles %}
<a href="{{ url_for('tags_web.lista_tags') }}" 
    class="flex items-center p-4 text-gray-700 rounded-lg hover:bg-blue-50 hover:text-blue-700 transition-all duration-200 group">
    <svg class="w-6 h-6 mr-4 text-gray-500 group-hover:text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" 
            d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"></path>
    </svg>
    <span class="font-medium">Gestión de Tags</span>
</a>
{% endif %}

<!-- Gestión de Usuarios (solo admin y superAdmin, NO editor ni usuario) -->
