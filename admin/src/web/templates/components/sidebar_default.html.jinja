<!-- Sidebar default content -->
<!-- Sitios Históricos -->
{% if current_user and (is_super_admin or current_user.has_permission('site_index')) %}
<a href="{{ url_for('sites_web.lista_sitios') }}" 
    class="flex items-center p-4 text-gray-700 rounded-lg hover:bg-blue-50 hover:text-blue-700 transition-all duration-200 group">
    <svg class="w-6 h-6 mr-4 text-gray-500 group-hover:text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" 
                d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path>
    </svg>
    <span class="font-medium">Gestión de Sitios Históricos</span>
    </a>
{% endif %}

<!-- Moderación de Reseñas -->
