<div class="space-y-4">
  <div class="border-b pb-4">
    <h4 class="text-lg font-semibold text-gray-800 mb-2">Reseña #{{ review.id }}</h4>
    <div class="flex items-center gap-4 text-sm text-gray-600">
      <span><strong>Sitio:</strong> {{ review.site_name or 'N/A' }}</span>
      <span><strong>Usuario:</strong> {{ review.user.mail if review.user else 'N/A' }}</span>
    </div>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
    <div class="bg-gray-50 p-3 rounded-lg">
      <h6 class="font-medium text-gray-700 mb-1">Calificación</h6>
      <div class="flex items-center gap-1">
        {% for i in range(1, 6) %}
          {% if i <= review.rating %}
            <span class="text-yellow-400">★</span>
          {% else %}
            <span class="text-gray-300">★</span>
          {% endif %}
        {% endfor %}
        <span class="ml-2 text-sm text-gray-600">({{ review.rating }}/5)</span>
      </div>
    </div>
    
    <div class="bg-gray-50 p-3 rounded-lg">
      <h6 class="font-medium text-gray-700 mb-1">Estado</h6>
      {% if review.status == 'pending' %}
        <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-semibold bg-yellow-100 text-yellow-800">Pendiente</span>
      {% elif review.status == 'approved' %}
        <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-semibold bg-green-100 text-green-800">Aprobada</span>
      {% elif review.status == 'rejected' %}
        <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-semibold bg-red-100 text-red-800">Rechazada</span>
      {% elif review.status == 'deleted' %}
        <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-semibold bg-gray-300 text-gray-700">Eliminada</span>
      {% else %}
        <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-semibold bg-gray-100 text-gray-800">{{ review.status }}</span>
      {% endif %}
    </div>
  </div>

  <div>
    <h5 class="font-semibold text-gray-700 mb-2">Contenido</h5>
    <p class="text-gray-600 leading-relaxed bg-gray-50 p-4 rounded-lg">{{ review.content }}</p>
  </div>

  {% if review.rejection_reason %}
  <div>
    <h5 class="font-semibold text-gray-700 mb-2">Motivo de rechazo</h5>
    <p class="text-gray-600 leading-relaxed bg-red-50 p-4 rounded-lg border border-red-200">{{ review.rejection_reason }}</p>
  </div>
  {% endif %}

  <div class="grid grid-cols-1 md:grid-cols-2 gap-4 text-sm">
    <div class="text-center p-2 bg-blue-50 rounded">
      <span class="font-medium text-blue-700">Fecha de creación</span>
      <p class="text-blue-600">{{ review.created_at | default('N/A') }}</p>
    </div>
    {% if review.user %}
    <div class="text-center p-2 bg-green-50 rounded">
      <span class="font-medium text-green-700">Usuario</span>
      <p class="text-green-600">{{ review.user.name or review.user.mail }}</p>
    </div>
    {% endif %}
  </div>
</div>

